# Smart Focus — 라즈베리파이 설정
# install.sh 실행 후 .env 로 복사됩니다.

# 아두이노 시리얼 포트 (ls /dev/ttyUSB* /dev/ttyACM* 로 확인)
BUZZER_SERIAL_PORT=/dev/ttyUSB0
BUZZER_SERIAL_BAUD=9600

# PC에서 컴퓨터 모드 부저 신호를 받는 UDP 포트
PI_BUZZER_UDP_PORT=9999

# Pi API 포트 (PC의 PI_BASE_URL 에 이 포트 사용)
PI_SERVICE_PORT=5001

# 카메라 (얼굴 인식은 해상도 640x480 권장)
CAMERA_DEVICE_INDEX=0
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_JPEG_QUALITY=55
CAMERA_STREAM_INTERVAL=0.2
CAMERA_PREVIEW_INTERVAL=0.15
CAMERA_ANALYZE_INTERVAL=0.8
CAMERA_FACE_ONLY=1
